    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "20.19.41",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.6"
  }
}
